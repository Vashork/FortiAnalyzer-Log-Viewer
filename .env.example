# ============================
# FortiAnalyzer Access
# ============================
FORTIANALYZER_URL=https://fortianalyzer-vm.diasoft.ru/jsonrpc
FORTIANALYZER_USERNAME=your_username
FORTIANALYZER_PASSWORD=your_password

# Default time range (если --start/--end не заданы)
#   DEFAULT_TIME_RANGE_HOURS=24 → брать последние 24 часа
DEFAULT_TIME_RANGE_HOURS=24

# Batch size for fetch_logs()
BATCH_SIZE=100

# Results directory
RESULTS_DIR=results

# Max workers for ThreadPoolExecutor (базовое значение, адаптивно режется в main.py)
MAX_WORKERS=1

# Лимит подряд идущих пустых батчей при fetch_logs
EMPTY_BATCH_LIMIT=30

# Where to read targets (если не передан --input и не используется --vlan)
MACHINES_FILE=machines.txt

# VLANs description file (VLAN → CIDR/range)
VLANS_FILE=vlans.txt

# Ports list for --proto mode
PORTS_FILE=ports.txt

# ---------------------------------------
# SMART ACTION / FILTER MODE
# ---------------------------------------
# SMART_ACTION управляет тем, какие логи считаются "интересными":
#   all        — не фильтровать по smart_action/action вообще
#   deny       — только заблокированные запросы (action = "deny")
#   all-accept — только полностью принятые запросы (smart_action="all-accept" или action="accept")
SMART_ACTION=all-accept

# Если FILTER_MODE=faz  → выражение из SMART_ACTION_MAP уходит прямо в фильтр FortiAnalyzer.
# Если FILTER_MODE=local → фильтрация происходит уже в Python после fetch_logs().
FILTER_MODE=faz

# ---------------------------------------
# Columns config
# ---------------------------------------
COLUMN_CONNECTIONS=false
COLUMN_ACTION=false
COLUMN_POLICYID=true
COLUMN_APP=true
COLUMN_SRCINTF=true
COLUMN_DSTINTF=true
COLUMN_POLICYNAME=false
COLUMN_DEVNAME=false

# ---------------------------------------
# FAZ load protection
# ---------------------------------------

# Максимальная длительность одного search-task в часах.
# Например, 4 → если общее окно 24 часа, то будет 6 task'ов по 4 часа.
# 0 → нарезка отключена (НЕ рекомендую).
MAX_TASK_HOURS=4

# Максимальное количество логов, которые мы готовы вытянуть для одного task.
# 0 → без лимита (может быть тяжело для FAZ).
MAX_MATCHED_LOGS_PER_TASK=200000

# Если общее временное окно (start→end) больше или равно этому порогу (в часах),
# то main.py принудительно выставит число воркеров = 1, даже если в .env больше.
# 0 → адаптивное ограничение отключено.
ADAPTIVE_WORKER_THRESHOLD_HOURS=24