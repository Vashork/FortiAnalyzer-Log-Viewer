# ============================
# FortiAnalyzer Access (ОБЯЗАТЕЛЬНО)
# ============================
FORTIANALYZER_URL=https://fortianalyzer-vm.diasoft.ru/jsonrpc
FORTIANALYZER_USERNAME=your_username
FORTIANALYZER_PASSWORD=your_password

# ============================
# Основные настройки
# ============================

# Default time range (если --start/--end не заданы)
DEFAULT_TIME_RANGE_HOURS=24

# Batch size для fetch_logs()
BATCH_SIZE=100

# Директория результатов
RESULTS_DIR=results

# Max workers для ThreadPoolExecutor
MAX_WORKERS=1

# Лимит подряд идущих пустых батчей при fetch_logs
EMPTY_BATCH_LIMIT=5

# ============================
# SMART ACTION / FILTER MODE
# ============================
# all        — не фильтровать по smart_action/action
# deny       — только заблокированные (action = "deny")
# all-accept — только полностью принятые (smart_action="all-accept" или action="accept")
SMART_ACTION=all

# faz  → выражение уходит прямо в фильтр FortiAnalyzer
# local → фильтрация в Python после fetch_logs()
FILTER_MODE=faz

# ============================
# Columns config
# ============================
COLUMN_CONNECTIONS=true
COLUMN_ACTION=false
COLUMN_POLICYID=true
COLUMN_APP=true
COLUMN_SRCINTF=true
COLUMN_DSTINTF=true
COLUMN_POLICYNAME=false
COLUMN_DEVNAME=false
COLUMN_SMART_ACTION=true

# ============================
# FAZ load protection
# ============================

# Максимальная длительность одного search-task в часах
MAX_TASK_HOURS=4

# Максимальное количество логов для одного task
MAX_MATCHED_LOGS_PER_TASK=200000

# Порог для адаптивного ограничения воркеров (часы)
ADAPTIVE_WORKER_THRESHOLD_HOURS=24

# ============================
# Режим дробления сессий
# ============================
# ip   — каждый воркер обрабатывает один IP (старая логика)
# time — каждый воркер получает свой временной период
SESSION_SPLIT_MODE=ip
