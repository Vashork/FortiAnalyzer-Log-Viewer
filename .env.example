# ============================
# FortiAnalyzer Access (ОБЯЗАТЕЛЬНО)
# ============================
FORTIANALYZER_URL=https://fortianalyzer-vm.diasoft.ru/jsonrpc
FORTIANALYZER_USERNAME=your_username
FORTIANALYZER_PASSWORD=your_password

# ============================
# Основные настройки
# ============================

# Default time range (если --start/--end не заданы)
DEFAULT_TIME_RANGE_HOURS=24

# Batch size для fetch_logs()
BATCH_SIZE=100

# Директория результатов
RESULTS_DIR=results

# Max workers для ThreadPoolExecutor
MAX_WORKERS=1

# Сколько target IP объединять в один FAZ search filter в direction mode.
# 1 сохраняет старое поведение: один FAZ task на один IP.
TARGET_GROUP_SIZE=1

# Лимит подряд идущих пустых батчей при fetch_logs
EMPTY_BATCH_LIMIT=5

# ============================
# FortiAnalyzer HTTP/TLS transport
# ============================
# Совместимый default для FAZ с self-signed сертификатом.
# Поставьте true после настройки нормального сертификата или CA bundle.
FORTIANALYZER_TLS_VERIFY=false
FORTIANALYZER_CA_BUNDLE=
FORTIANALYZER_POOL_CONNECTIONS=10
FORTIANALYZER_POOL_MAXSIZE=10
FORTIANALYZER_CONNECT_TIMEOUT=5
FORTIANALYZER_READ_TIMEOUT=30
FORTIANALYZER_RETRY_ATTEMPTS=3
FORTIANALYZER_RETRY_BACKOFF_SECONDS=1

# ============================
# SMART ACTION / FILTER MODE
# ============================
# all        — не фильтровать по smart_action/action
# deny       — только заблокированные (action = "deny")
# all-accept — только полностью принятые (smart_action="all-accept" или action="accept")
SMART_ACTION=all

# faz  → выражение уходит прямо в фильтр FortiAnalyzer
# local → фильтрация в Python после fetch_logs()
FILTER_MODE=faz

# ============================
# Columns config
# ============================
COLUMN_CONNECTIONS=true
COLUMN_ACTION=false
COLUMN_POLICYID=true
COLUMN_APP=true
COLUMN_SRCPORT=false
COLUMN_SRCINTF=true
COLUMN_DSTINTF=true
COLUMN_POLICYNAME=false
COLUMN_DEVNAME=false
COLUMN_SMART_ACTION=true

# ============================
# Aggregation fields
# ============================
# Direction mode default key: Remote IP + Dstport + Proto inside each local IP report.
# Remote IP is Srcip for inbound and Dstip for outbound.
# PolicyID mode default key: Srcip + Dstip + Dstport + Proto + PolicyID.
AGGREGATE_REMOTE_IP=true
AGGREGATE_SRCIP=true
AGGREGATE_DSTIP=true
AGGREGATE_PORT=true
AGGREGATE_PROTO=true
AGGREGATE_POLICYID=true

# ============================
# FAZ load protection
# ============================

# Максимальная длительность одного search-task в часах
MAX_TASK_HOURS=4

# Максимальное количество логов для одного task
MAX_MATCHED_LOGS_PER_TASK=200000

# Порог для адаптивного ограничения воркеров (часы)
ADAPTIVE_WORKER_THRESHOLD_HOURS=24

# ============================
# Web API validation limits
# ============================
MAX_WEB_WORKERS_LIMIT=32
MAX_ACTIVE_ANALYSIS_JOBS=2
MAX_TIME_HOURS_LIMIT=8760
MAX_TIME_DAYS_LIMIT=365
MAX_POLICY_IDS_LIMIT=100
MAX_TARGETS_LIMIT=1024
MAX_EXPANDED_TARGETS_LIMIT=4096
MAX_RESULT_PREVIEW_BYTES=1048576

# Comma-separated Web origins allowed by CORS. Wildcard '*' is intentionally ignored.
WEB_CORS_ALLOW_ORIGINS=http://127.0.0.1:8500,http://localhost:8500

# Reverse DNS lookup в отчетах:
# false — включен PTR resolve
# true  — отключен, в колонке Hostname останется IP
DISABLE_REVERSE_DNS=false
REVERSE_DNS_TIMEOUT=0.3
REVERSE_DNS_WORKERS=16
REVERSE_DNS_CACHE_TTL_SECONDS=86400
REVERSE_DNS_CACHE_SIZE=10000
# Если в одном отчете больше уникальных IP, PTR lookup автоматически пропускается.
# 0 — не ограничивать.
REVERSE_DNS_MAX_UNIQUE_IPS=1000

# ============================
# Режим дробления сессий
# ============================
# ip   — каждый воркер обрабатывает один IP (старая логика)
# time — каждый воркер получает свой временной период
SESSION_SPLIT_MODE=ip
